{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:enableMajor",
    ":disableRateLimiting",
    ":dependencyDashboard",
    ":semanticCommits",
    ":automergeBranch"
  ],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Renovate Dashboard",
  "suppressNotifications": ["prEditedNotification", "prIgnoreNotification"],
  "rebaseWhen": "conflicted",
  "commitMessageTopic": "{{depName}}",
  "commitMessageExtra": "to {{newVersion}}",
  "commitMessageSuffix": "",
  "flux": {
    "fileMatch": ["kubernetes/.+\\.ya?ml$"]
  },
  "helm-values": {
    "fileMatch": ["kubernetes/.+\\.ya?ml$"]
  },
  "kubernetes": {
    "fileMatch": ["kubernetes/.+\\.ya?ml$"]
  },
  "regexManagers": [
    {
      "description": "Process HelmRelease chart versions",
      "fileMatch": ["kubernetes/.+\\.ya?ml$"],
      "matchStrings": [
        "chart:\\s*\\n\\s*spec:\\s*\\n\\s*chart:\\s*(?<depName>\\S+)\\s*\\n\\s*version:\\s*(?<currentValue>\\S+)\\s*\\n\\s*sourceRef:\\s*\\n\\s*kind:\\s*HelmRepository\\s*\\n\\s*name:\\s*(?<registryUrl>\\S+)"
      ],
      "datasourceTemplate": "helm",
      "registryUrlTemplate": "{{#if (eq registryUrl 'bjw-s')}}https://bjw-s.github.io/helm-charts{{else if (eq registryUrl 'cilium')}}https://helm.cilium.io{{else if (eq registryUrl 'traefik')}}https://traefik.github.io/charts{{else if (eq registryUrl 'jetstack')}}https://charts.jetstack.io{{else if (eq registryUrl 'external-secrets')}}https://charts.external-secrets.io{{else if (eq registryUrl 'democratic-csi')}}https://democratic-csi.github.io/charts{{else if (eq registryUrl 'tailscale')}}https://pkgs.tailscale.com/helmcharts{{else if (eq registryUrl 'nvidia')}}https://helm.ngc.nvidia.com/nvidia{{else if (eq registryUrl 'fairwinds-stable')}}https://charts.fairwinds.com/stable{{else if (eq registryUrl 'authentik')}}https://charts.goauthentik.io{{else}}{{registryUrl}}{{/if}}"
    }
  ],
  "packageRules": [
    {
      "description": "Auto-merge minor and patch updates",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "description": "Major updates require manual review",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["major-update"]
    },
    {
      "description": "Cilium always requires manual review",
      "matchPackageNames": ["cilium"],
      "matchDatasources": ["helm"],
      "automerge": false,
      "labels": ["networking", "cilium"]
    },
    {
      "description": "Group bjw-s app-template updates",
      "matchPackagePatterns": ["^app-template$"],
      "groupName": "bjw-s app-template"
    },
    {
      "description": "Security updates",
      "matchPackagePatterns": [".*"],
      "matchUpdateTypes": ["patch"],
      "matchCurrentVersion": "/^[0-9]+\\.[0-9]+\\.[0-9]+$/",
      "labels": ["security"]
    }
  ]
}
